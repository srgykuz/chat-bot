# Telegram Configuration
# Get your token from BotFather: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# For local development, use: http://localhost:8000/webhook
# For production, use: https://yourdomain.com/webhook
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# LLM API Keys (choose at least one)
# Get from: https://console.cloud.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Redis Configuration (use default for Docker Compose)
REDIS_URL=redis://redis:6379

# Development options
TELEGRAM_USE_POLLING=false

# Environment
ENVIRONMENT=development

# Path to the system prompt template file used by the LLM client. Defaults to ./llm/system.txt
# You can set an absolute path or a path relative to the project root.
SYSTEM_PROMPT_TEMPLATE_PATH=./llm/system.txt

# Path to the LLM parameters file used by the LLM client. Defaults to ./llm/params.json
# You can set an absolute path or a path relative to the project root.
LLM_PARAMS_PATH=./llm/params.json
